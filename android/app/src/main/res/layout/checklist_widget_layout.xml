        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginBottom="6dp" />

    <TextView
        android:id="@+id/checklist_item_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#CCFFFFFF"
        android:textSize="13sp"
